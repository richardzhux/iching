{"chapter_id":"zzq.pattern.direct-officer","diplomatic_text":"至若地支刑冲會合可解","id":"zzq.seg.officer.closing.doctrine","layer":"shen_core","locator_ids":["loc.gc.officer.59","loc.qin.officer.137","loc.world.officer.67"],"normalized_search_text":"至若地支刑衝會合可解","review_state":"scan_verified","text_type":"rescue_rule"}
